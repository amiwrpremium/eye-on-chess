# ──────────────────────────────────────────────────────────
# EyeOnChess Configuration
# Copy this file to .env and customize for your deployment
# ──────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────
# Set to "production" in production (enables secure cookies, etc.)
NODE_ENV=development
# Log level: fatal, error, warn, info, debug, trace (default: info in prod, debug in dev)
# LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────
# PostgreSQL password — used by Postgres, PgBouncer, and connection strings
# IMPORTANT: Generate a random string (e.g. openssl rand -hex 16)
POSTGRES_PASSWORD=change-me-to-a-random-password
# PostgreSQL connection string (used by Prisma ORM at runtime)
# In Docker, connection strings are constructed by docker-compose using POSTGRES_PASSWORD
DATABASE_URL=postgresql://postgres:change-me-to-a-random-password@postgres:5432/eyeonchess
# Direct Postgres connection for migrations (bypasses PgBouncer)
# Set automatically by Docker Compose — only override if needed
# DIRECT_DATABASE_URL=postgresql://postgres:change-me-to-a-random-password@postgres:5432/eyeonchess

# ── Redis ────────────────────────────────────────────────
# Redis password — used by Redis server and connection string
# IMPORTANT: Generate a random string (e.g. openssl rand -hex 16)
REDIS_PASSWORD=change-me-to-a-random-password
# Redis connection string (presence, game clocks, analysis job queue)
REDIS_URL=redis://:change-me-to-a-random-password@redis:6379

# ── JWT Auth ─────────────────────────────────────────────
# Secret key for signing JWT tokens
# IMPORTANT: Generate a random string for production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# ── API URLs ─────────────────────────────────────────────
# Internal Docker network URL (used by server-side code)
API_URL=http://api:3001
# Public URL (used by the browser — routed through Nginx)
NEXT_PUBLIC_API_URL=http://localhost

# ── Site Configuration ───────────────────────────────────
# Display name for the platform (supports white-labeling)
SITE_NAME=EyeOnChess
# Public URL of the site (used in links, metadata)
SITE_URL=http://localhost

# ── Registration ─────────────────────────────────────────
# Set to "false" to close new user registrations
REGISTRATION_OPEN=true
# Maximum number of users allowed (0 = unlimited)
MAX_USERS=0
# Require email verification before login
# Note: No email sending is implemented — verification must be done manually in the DB
REQUIRE_EMAIL_VERIFICATION=false

# ── Seed User (Admin) ───────────────────────────────────
# Created automatically on first boot with verified=true
# Change the password before deploying!
SEED_USER_EMAIL=admin@eyeonchess.local
SEED_USER_USERNAME=admin
SEED_USER_PASSWORD=changeme123

# ── Stockfish (Worker) ──────────────────────────────────
# Path to the Stockfish binary (auto-detected in Docker)
# Only change this if stockfish is installed in a non-standard location
# STOCKFISH_PATH=stockfish

# ── SSL (optional) ──────────────────────────────────────
# Set SITE_DOMAIN to enable automatic HTTPS via Let's Encrypt
# Leave empty for HTTP-only mode (localhost/development)
# When set, Certbot obtains and auto-renews certificates
SITE_DOMAIN=
# Required when SITE_DOMAIN is set — used for Let's Encrypt notifications
CERTBOT_EMAIL=

# ── Observability (Grafana) ─────────────────────────────
# Grafana admin credentials (production docker-compose only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Port for Grafana UI (default 3003)
GRAFANA_PORT=3003
