FROM node:22-bookworm-slim AS base

LABEL org.opencontainers.image.source="https://github.com/amiwrpremium/eye-on-chess"
LABEL org.opencontainers.image.description="EyeOnChess base image"

RUN apt-get update && \
    apt-get install -y --no-install-recommends openssl wget && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm@10.32.1

WORKDIR /app
