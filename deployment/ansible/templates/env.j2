# ──────────────────────────────────────────────────────────
# EyeOnChess Configuration — Generated by Ansible
# ──────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────
NODE_ENV=production

# ── Database ─────────────────────────────────────────────
POSTGRES_PASSWORD={{ postgres_password }}
# Runtime connection (via PgBouncer — overridden by docker-compose environment)
DATABASE_URL=postgresql://postgres:{{ postgres_password }}@pgbouncer:6432/eyeonchess?pgbouncer=true
# Direct connection for migrations (bypasses PgBouncer — overridden by docker-compose environment)
DIRECT_DATABASE_URL=postgresql://postgres:{{ postgres_password }}@postgres:5432/eyeonchess

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD={{ redis_password }}
REDIS_URL=redis://:{{ redis_password }}@redis:6379

# ── JWT Auth ─────────────────────────────────────────────
JWT_SECRET={{ jwt_secret }}

# ── API URLs ─────────────────────────────────────────────
API_URL=http://api:3001
NEXT_PUBLIC_API_URL={{ site_url | default('http://localhost') }}

# ── Site Configuration ───────────────────────────────────
SITE_NAME={{ site_name | default('EyeOnChess') }}
SITE_URL={{ site_url | default('http://localhost') }}
ADMIN_URL={{ admin_url | default(site_url | default('http://localhost') | regex_replace('://', '://admin.')) }}
NEXT_PUBLIC_ADMIN_URL={{ admin_url | default(site_url | default('http://localhost') | regex_replace('://', '://admin.')) }}
NEXT_PUBLIC_SITE_URL={{ site_url | default('http://localhost') }}

# ── Registration ─────────────────────────────────────────
REGISTRATION_OPEN={{ registration_open | default('true') }}
MAX_USERS={{ max_users | default('0') }}
REQUIRE_EMAIL_VERIFICATION={{ require_email_verification | default('false') }}

# ── Seed User (Admin) ───────────────────────────────────
SEED_USER_EMAIL={{ seed_user_email | default('admin@eyeonchess.local') }}
SEED_USER_USERNAME={{ seed_user_username | default('admin') }}
SEED_USER_PASSWORD={{ seed_user_password }}

# ── SSL ──────────────────────────────────────────────────
SITE_DOMAIN={{ site_domain | default('') }}
CERTBOT_EMAIL={{ certbot_email | default('') }}
CERTBOT_DOMAINS={{ certbot_domains | default(site_domain | default('')) }}

# ── Docker Images ────────────────────────────────────────
IMAGE_TAG={{ image_tag | default('latest') }}
IMAGE_PREFIX={{ image_prefix | default('ghcr.io/amiwrpremium/eye-on-chess') }}

# ── Observability (Grafana) ─────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password }}
GRAFANA_PORT=3003
