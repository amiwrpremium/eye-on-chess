# ── Shared settings ───────────────────────────────────────
gzip on;
gzip_vary on;
gzip_proxied any;
gzip_comp_level 6;
gzip_min_length 256;
gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    image/svg+xml
    font/woff2;

proxy_buffering on;
proxy_buffer_size 16k;
proxy_buffers 8 16k;

upstream web {
    server web:3000;
}

upstream api {
    server api:3001;
}

upstream grafana_backend {
    server grafana:3000;
}

# ── SSL settings ─────────────────────────────────────────
ssl_certificate /etc/letsencrypt/live/${SITE_DOMAIN}/fullchain.pem;
ssl_certificate_key /etc/letsencrypt/live/${SITE_DOMAIN}/privkey.pem;
ssl_protocols TLSv1.2 TLSv1.3;
ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
ssl_prefer_server_ciphers off;
ssl_session_timeout 1d;
ssl_session_cache shared:SSL:10m;
ssl_session_tickets off;

# ── HTTP → HTTPS redirect + ACME challenge ───────────────
server {
    listen 80;
    server_name ${SITE_DOMAIN} grafana.${SITE_DOMAIN};

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect everything else to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# ── Main site (HTTPS) ───────────────────────────────────
server {
    listen 443 ssl;
    http2 on;
    server_name ${SITE_DOMAIN};

    client_max_body_size 10M;

    # HSTS (1 year)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Next.js static assets (immutable — hashed filenames)
    location /_next/static/ {
        proxy_pass http://web;
        proxy_set_header Host $host;
        expires 365d;
        add_header Cache-Control "public, immutable";
    }

    # Public static files (icons, sounds, images)
    location ~* \.(png|jpg|jpeg|gif|webp|svg|ico|woff2?|ttf|eot|mp3|wav|ogg|wasm)$ {
        proxy_pass http://web;
        proxy_set_header Host $host;
        expires 30d;
        add_header Cache-Control "public";
    }

    # Bot list (cached — rarely changes)
    location = /api/v1/bots {
        proxy_pass http://api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header Cache-Control "public, max-age=3600";
    }

    # API v1 routes
    location /api/v1/ {
        proxy_pass http://api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header Cache-Control "no-store";
    }

    # Backward-compat: /api/* → /api/v1/* (only non-v1 paths)
    location ~ ^/api/(?!v1/) {
        rewrite ^/api/(.*)$ /api/v1/$1 permanent;
    }

    # Health check
    location /health {
        proxy_pass http://api;
    }

    # Prometheus metrics (internal only)
    location /metrics {
        allow 127.0.0.1;
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        deny all;
        proxy_pass http://api;
    }

    # Socket.io
    location /socket.io/ {
        proxy_pass http://api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400;
    }

    # Everything else → Next.js
    location / {
        proxy_pass http://web;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# ── Grafana subdomain (HTTPS) ───────────────────────────
server {
    listen 443 ssl;
    http2 on;
    server_name grafana.${SITE_DOMAIN};

    client_max_body_size 10M;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://grafana_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Grafana live WebSocket
    location /api/live/ {
        proxy_pass http://grafana_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}
